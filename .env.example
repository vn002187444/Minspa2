# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# ⚠ Service role key có quyền bypass RLS — KHÔNG commit, chỉ dùng local/dev
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === Gemini AI ===
GEMINI_API_KEY=your_gemini_api_key

# === JWT (dùng mã hoá session cookie) ===
JWT_SECRET=your_jwt_secret_at_least_32_chars

# === VAPID Web Push ===
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
WEB_PUSH_EMAIL=mailto:hang.ntt0903@gmail.com

# === Cron (bảo vệ webhook cron) ===
CRON_SECRET=your_cron_secret

# === Google Analytics ===
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# === Sentry (Error Monitoring) ===
SENTRY_DSN=https://example@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://example@o0.ingest.sentry.io/0

# === Notifications (Zalo OA, Resend Email) ===
ZALO_ACCESS_TOKEN=your_zalo_access_token
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=system@minnailhair.com

# === Unsplash (AI generate image fallback) ===
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# === Pexels (alternative image search if Unsplash unavailable) ===
PEXELS_API_KEY=your_pexels_api_key

# === Postgres Direct (dùng cho migration scripts, tránh PgBouncer) ===
POSTGRES_URL=postgres://postgres:password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x
POSTGRES_URL_NON_POOLING=postgres://postgres:password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# === Bank Info (hiển thị trên booking + invoice) ===
NEXT_PUBLIC_HOTLINE=0900-000-000
BANK_ACCOUNT_NUMBER=1234567890
BANK_ACCOUNT_OWNER=MIN NAIL & HAIR
BANK_NAME=Vietcombank
BANK_ID=VCB

# === Login Bypass (fallback khi DB không available) ===
BYPASS_ADMIN_USER=admin
BYPASS_ADMIN_PASS=Admin
BYPASS_STAFF1_USER=staff1
BYPASS_STAFF1_PASS=Staff@1
